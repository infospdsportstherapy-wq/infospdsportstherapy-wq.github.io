# =============================================================================
# SPD Sports Therapy - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# DO NOT commit .env to version control (contains sensitive credentials)
# =============================================================================

# Database Configuration
# For Docker: db_host should be 'mysql', for local: 'localhost'
DB_HOST=mysql
DB_NAME=spd_sports_therapy
DB_USER=spd_user
DB_PASSWORD=change_me_to_secure_password_12345
DB_PORT=3306

# Site Configuration
SITE_URL=http://localhost:8000
ADMIN_EMAIL=info.spdsportstherapy@gmail.com

# =============================================================================
# Gmail SMTP Configuration (for email notifications)
# =============================================================================
# To set up Gmail SMTP:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your device)
# 3. Google will generate a 16-character password
# 4. Copy that password below (without spaces)
# =============================================================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password-here
MAIL_FROM_NAME=SPD Sports Therapy
MAIL_FROM_EMAIL=your-email@gmail.com

# Email Settings
MAIL_DEBUG=0

# Database Connection Pool (optional)
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Application Environment
APP_ENV=development
APP_DEBUG=1
